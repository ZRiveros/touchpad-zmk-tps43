/*
 * Minimal keymap for a touchpad-only device.
 * No real keys exist — mock kscan with a dummy binding.
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <&none>;
        };
    };
};
